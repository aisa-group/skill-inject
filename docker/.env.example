# API keys for agent execution inside Docker containers.
# Copy this file to docker/.env and fill in your keys:
#   cp docker/.env.example docker/.env
#
# You only need the key(s) for the agent(s) you want to test.

# Required for Claude Code agent
ANTHROPIC_API_KEY=

# Required for Codex agent and GPT-5.1-Mini judge
OPENAI_API_KEY=

# Required for Gemini CLI agent
GEMINI_API_KEY=

# Optional
GOOGLE_API_KEY=
HF_TOKEN=
MISTRAL_API_KEY=
